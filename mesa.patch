+         dev = kgsl_device_new(kgsl_fd);
+         if (dev) {
+            /* Userspace fences are not supported with KGSL */
+            support_use_heap = false;
+            gpu_fd = kgsl_fd;   /* render on kgsl, keep fd as control_fd */
+            goto out;
+         }
+         close(kgsl_fd);
+      }
+   }
+#endif
